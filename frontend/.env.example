# Target network — one of: devnet | mainnet
# Drives the default RPC + explorer host unless you override them below.
VITE_ONS_NETWORK=devnet

# Deployed contract address on the target network.
# VITE_ONS_CONTRACT=oct4BkKJyYUrnd1tcRqVLmqMgbDL52q9a2WBzkbR34VBVAj

# Override the JSON-RPC endpoint (optional — leave blank to use the default
# for the selected network).
# VITE_ONS_RPC=http://165.227.225.79:8080

# Override the explorer host (optional — leave blank to use the default
# for the selected network).
# VITE_ONS_EXPLORER=https://devnet.octrascan.io
