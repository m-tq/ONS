# ONS script suite — env template.
#
# Copy this file to `.env`, then optionally add `.env.devnet` / `.env.mainnet`
# to override individual fields per-network.
#
# Precedence (first match wins per key):
#
#   1. shell env          ONS_NETWORK=mainnet npm run deploy
#   2. .env.<network>     e.g. .env.mainnet
#   3. .env               this file

# ─── Core ────────────────────────────────────────────────────────────────

# devnet | mainnet  — drives default RPC + explorer + deployment.<network>.json
ONS_NETWORK=devnet

# Deployer credentials. Required for deploy / save-abi / verify / test.
ONS_DEPLOYER_ADDR=
ONS_DEPLOYER_PRIV=

# ─── Network endpoints (optional — defaults per-network are built in) ────

# ONS_RPC=http://165.227.225.79:8080
# ONS_EXPLORER=https://devnet.octrascan.io

# ─── Economics (baked into the constructor at deploy time) ───────────────

ONS_PRICE_PER_YEAR_OU=500000
ONS_FEE_BPS=250
ONS_GRACE_EPOCHS=259200

# ─── Fee budgets for the scripts ─────────────────────────────────────────

ONS_DEPLOY_FEE_OU=200000
ONS_CALL_FEE_OU=1000
